//이용절차에 움직이는 기능 삭제하기
//신청서 확인하는 기능 추가 건 상의하기(db만들기?)




<!DOCTYPE html>
<html lang="ko" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>시설 대관 안내 | 부산도서관</title>
    <style>
        /* 기본 폰트 및 레이아웃 설정 */
        body {
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
            line-height: 1.6;
            color: #333;
            margin: 0;
            padding: 20px;
            background-color: #fcfcfc;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: #fff;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 0 20px rgba(0,0,0,0.05);
        }

        /* 제목 스타일 */
        h1 { text-align: center; color: #222; margin-bottom: 50px; }
        h2 {
            border-left: 5px solid #007bff;
            padding-left: 15px;
            color: #0056b3;
            margin-top: 40px;
            font-size: 1.4rem;
        }

        /* 1. 이용 절차 스타일 (화살표 포함) */
        .step-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 30px 0;
        }
        .step-box {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 12px;
            padding: 20px 10px;
            width: 20%;
            text-align: center;
            transition: transform 0.2s;
        }
        .step-box:hover { transform: translateY(-5px); background: #f1f3f5; }
        .step-num {
            display: block;
            font-weight: bold;
            color: #007bff;
            font-size: 1.3rem;
            margin-bottom: 8px;
        }
        .step-arrow {
            font-size: 24px;
            color: #adb5bd;
            font-weight: bold;
        }

        /* 2. 시설 안내 표 스타일 */
        .table-wrapper { margin-top: 20px; overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 600px; }
        th, td { border: 1px solid #e9ecef; padding: 15px; text-align: center; }
        th { background-color: #f8f9fa; color: #495057; font-weight: 600; }
        tr:hover { background-color: #fafafa; }

        /* 3. 이용 시간 리스트 스타일 */
        .info-list { background: #f3f3f3; padding: 20px 40px; border-radius: 10px; list-style-type: square; }
        .info-list li { margin-bottom: 8px; }

        /* 신청 폼 스타일 */
        .apply-form-wrapper {
            margin-top: 20px;
            padding: 30px;
            background: #f9f9f9;
            border: 1px solid #eee;
            border-radius: 12px;
        }
        .form-section { margin-bottom: 30px; }
        .form-section h3 { font-size: 1.1rem; color: #444; border-bottom: 1px solid #ddd; padding-bottom: 10px; margin-bottom: 20px; }

        .form-group { margin-bottom: 15px; display: flex; flex-direction: column; flex: 1; }
        .form-group-row { display: flex; gap: 20px; margin-bottom: 15px; }

        label { font-weight: 600; margin-bottom: 8px; font-size: 0.95rem; color: #555; }
        input[type="text"], input[type="tel"], input[type="date"], input[type="number"], select, textarea {
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 1rem;
            font-family: inherit;
        }
        input:focus, select:focus, textarea:focus { border-color: #007bff; outline: none; box-shadow: 0 0 5px rgba(0,123,255,0.2); }

        /* 제출 버튼 컨테이너 (우측 정렬) */
        .button-container {
            text-align: right;
            margin: 40px 0 10px 0;
        }

        /* 제출 버튼 스타일 */
        .btn-submit {
            padding: 15px 50px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 35px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
            transition: all 0.3s;
        }
        .btn-submit:hover { background-color: #0056b3; transform: scale(1.02); }

        /* 하단 안내 문구 스타일 */
        .contact-info {
            margin-top: 30px;
            padding: 20px;
            background-color: #f1f3f5;
            border-radius: 10px;
            text-align: center;
            color: #666;
            font-size: 0.95rem;
            border: 1px dashed #adb5bd;
        }
        .contact-info strong { color: #007bff; text-decoration: underline; }

        /* 필수 입력 표시(별표) 스타일 */
        .required { color: #e74c3c; margin-left: 3px; }

        /* 폼 하단 안내 문구 스타일 */
        .form-notice {
            font-size: 0.85rem;
            color: #e74c3c;
            margin-bottom: 10px;
            text-align: right;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>🏛️ 도서관 시설 대관 안내</h1>

    <h2>■ 시설대관 이용절차</h2>
    <div class="step-container">
        <div class="step-box">
            <span class="step-num">01</span>사용신청<br>(방문/온라인)
        </div>
        <div class="step-arrow">&gt;</div>
        <div class="step-box">
            <span class="step-num">02</span>사용승인<br>(7일 이내 통지)
        </div>
        <div class="step-arrow">&gt;</div>
        <div class="step-box">
            <span class="step-num">03</span>사용료 납부<br>(기한 내)
        </div>
        <div class="step-arrow">&gt;</div>
        <div class="step-box">
            <span class="step-num">04</span>시설 사용<br>(행사 진행)
        </div>
    </div>

    <h2>■ 대관 시설 현황</h2>
    <div class="table-wrapper">
        <table>
            <thead>
            <tr>
                <th>구분</th>
                <th>위치</th>
                <th>면적</th>
                <th>좌석수</th>
                <th>비고</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <td><strong>회의실</strong></td>
                <td>지하 1층</td>
                <td>165.35㎡</td>
                <td>80석</td>
                <td>-</td>
            </tr>
            <tr>
                <td><strong>극장</strong></td>
                <td>지하 1층</td>
                <td>540.45㎡</td>
                <td>227석</td>
                <td>그랜드 피아노 사용 가능</td>
            </tr>
            <tr>
                <td><strong>전시실</strong></td>
                <td>2층</td>
                <td>164.61㎡</td>
                <td>-</td>
                <td>작품 전시 전용</td>
            </tr>
            </tbody>
        </table>
    </div>

    <h2>■ 이용 시간 및 주의사항</h2>
    <ul class="info-list">
        <li><strong>화 ~ 금</strong> : 09:00 ~ 22:00 (단, 전시실은 18:00까지 운영)</li>
        <li><strong>토, 일</strong> : 09:00 ~ 17:00</li>
        <li><strong>매주 월요일</strong> 및 법정 공휴일은 휴관으로 인해 대관이 불가합니다.</li>
        <li>시설 이용 문의 : 관리팀 (051-123-4567)</li>
    </ul>

    <h2>■ 온라인 시설 대관 신청하기</h2>
    <div class="apply-form-wrapper">
        <p class="form-notice">* 표시는 필수 입력 항목입니다.</p>

        <form id="applyForm" action="#" method="post">
            <div class="form-section">
                <h3>[1] 신청인 정보</h3>
                <div class="form-group-row">
                    <div class="form-group">
                        <label>신청자<span class="required">*</span></label>
                        <input type="text" name="applicantName" placeholder="성명을 입력하세요.">
                    </div>
                </div>
                <div class="form-group-row">
                    <div class="form-group">
                        <label>연락처<span class="required">*</span></label>
                        <input type="tel" name="phone" placeholder="010-0000-0000">
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3>[2] 신청 내용</h3>
                <div class="form-group">
                    <label>행사명<span class="required">*</span></label>
                    <input type="text" name="eventName" placeholder="행사 제목을 입력하세요.">
                </div>
                <div class="form-group-row">
                    <div class="form-group">
                        <label>사용 신청시설<span class="required">*</span></label>
                        <select name="facilityType">
                            <option value="">-- (선택) --</option>
                            <option value="회의실">회의실 (지하 1층)</option>
                            <option value="극장">극장 (지하 1층)</option>
                            <option value="전시실">전시실 (2층)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>참석인원<span class="required">*</span></label>
                        <input type="number" name="participants" placeholder="명">
                    </div>
                </div>
                <div class="form-group-row">
                    <div class="form-group">
                        <label>사용 신청기간<span class="required">*</span></label>
                        <input type="date" name="applyDate">
                    </div>
                    <div class="form-group">
                        <label>사용 시간대<span class="required">*</span></label>
                        <select name="applyTime">
                            <option value="오전">오전 (09:00~12:00)</option>
                            <option value="오후">오후 (13:00~17:00)</option>
                            <option value="야간">야간 (18:00~22:00)</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>행사내용</label>
                    <textarea name="eventContent" rows="4" placeholder="행사 목적 및 상세 내용을 입력하세요."></textarea>
                </div>
            </div>

            <div class="button-container">
                <button type="submit" class="btn-submit">신청서 제출하기</button>
            </div>
        </form>
    </div>

    <div class="contact-info">
        <p>💡 방문 신청 희망 시 <strong>관리팀 (051-123-4567)</strong>으로 문의해 주시기 바랍니다.</p>
    </div>

</div>

<script th:inline="javascript">
    document.getElementById('applyForm').addEventListener('submit', function(e) {
        const applicantName = document.getElementsByName('applicantName')[0].value.trim();
        const phone = document.getElementsByName('phone')[0].value.trim();
        const eventName = document.getElementsByName('eventName')[0].value.trim();
        const facilityType = document.getElementsByName('facilityType')[0].value;
        const participants = document.getElementsByName('participants')[0].value.trim();
        const applyDate = document.getElementsByName('applyDate')[0].value.trim();

        if (!applicantName) { alert('신청자 성명을 입력해주세요.'); e.preventDefault(); return; }
        if (!phone) { alert('연락처를 입력해주세요.'); e.preventDefault(); return; }
        if (!eventName) { alert('행사명을 입력해주세요.'); e.preventDefault(); return; }
        if (!facilityType) { alert('사용 신청시설을 선택해주세요.'); e.preventDefault(); return; }
        if (!participants) { alert('참석인원을 입력해주세요.'); e.preventDefault(); return; }
        if (!applyDate) { alert('사용 신청기간(날짜)을 선택해주세요.'); e.preventDefault(); return; }

        // 최종 성공 시 처리
        alert('신청서가 정상적으로 제출되었습니다!');
        e.preventDefault();
        location.href = '/apply/info';
    });
</script>

</body>
</html>